{
  "manifest_version": 2,
  "id": "davidblackcn.maibot-api-balance-plugin",
  "version": "1.1.0",
  "name": "API 余额查询",
  "description": "一键查询众多API平台账号余额",
  "author": {
    "name": "DavidBlackCN",
    "url": "https://github.com/DavidBlackCN"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/DavidBlackCN/maibot-api-balance-plugin",
    "homepage": "https://github.com/DavidBlackCN/maibot-api-balance-plugin",
    "documentation": "https://github.com/DavidBlackCN/maibot-api-balance-plugin/blob/main/README.md",
    "issues": "https://github.com/DavidBlackCN/maibot-api-balance-plugin/issues"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "2.99.99"
  },
  "sdk": {
    "min_version": "1.0.0",
    "max_version": "2.99.99"
  },
  "capabilities": [
    "send.text",
    "send.image",
    "render.html2png",
    "component.reload_plugin"
  ],
  "dependencies": [
    {
      "type": "python_package",
      "name": "tomli",
      "version_spec": ">=2.0.0"
    },
    {
      "type": "python_package",
      "name": "tomli_w",
      "version_spec": ">=1.0.0"
    }
  ],
  "i18n": {
    "default_locale": "zh-CN",
    "locales_path": "_locales",
    "supported_locales": ["zh-CN"]
  }
}