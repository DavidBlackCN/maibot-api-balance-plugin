{
  "manifest_version": 2,
  "id": "maibot-api-balance-plugin",
  "version": "1.1.0",
  "name": "API 余额查询",
  "description": "一键查询 DeepSeek / SiliconFlow / NewAPI / OpenRouter / Moonshot / OpenAI / OneThing / MiniMax 平台账号余额",
  "author": {
    "name": "MaiBot Community",
    "url": "https://github.com"
  },
  "license": "MIT",
  "urls": {
    "repository": "https://github.com/user/maibot-api-balance-plugin"
  },
  "host_application": {
    "min_version": "1.0.0",
    "max_version": "2.99.99"
  },
  "sdk": {
    "min_version": "1.0.0",
    "max_version": "2.99.99"
  },
  "capabilities": [
    "send.text",
    "send.image",
    "render.html2png",
    "component.reload_plugin"
  ],
  "dependencies": [
    {
      "type": "python_package",
      "name": "tomli",
      "version": ">=2.0.0"
    },
    {
      "type": "python_package",
      "name": "tomli_w",
      "version": ">=1.0.0"
    }
  ],
  "i18n": {
    "default_locale": "zh-CN"
  }
}
